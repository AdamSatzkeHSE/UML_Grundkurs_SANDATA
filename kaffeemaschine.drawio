<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36" version="29.6.6" pages="2">
  <diagram name="Anforderungsanalyse" id="YqSJJECzeSLrmL5LTIEo">
    <mxGraphModel dx="1107" dy="674" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2339" pageHeight="3300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ss95rz__1RLRhlweLFFE-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="F1: Der Benutzer kann ein Getränk wählen&lt;div&gt;F2: Die Maschine prüft vor dem Brühvorgang, ob genugend Wasser&lt;/div&gt;&lt;div&gt;F3: Die Maschine prüft vor dem Brühvorgang, ob genügend Bohnen vorhanden sind.&lt;/div&gt;&lt;div&gt;F4: Die Maschine brüht den Kaffee und füllt ihn in die Tasse&lt;/div&gt;&lt;div&gt;F5: Das System soll Fehler erkennen und melden&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="250" x="80" y="680" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="4. Funktionale Anforderungen" vertex="1">
          <mxGeometry height="30" width="160" x="80" y="650" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="2. Stakeholder" vertex="1">
          <mxGeometry height="30" width="90" x="80" y="430" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="- Benutzer&lt;div&gt;- Wartungspersonal&lt;/div&gt;&lt;div&gt;- Hersteller / Techniker&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="250" x="80" y="460" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="1. Ziel" vertex="1">
          <mxGeometry height="30" width="60" x="80" y="220" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-6" parent="1" style="whiteSpace=wrap;html=1;" value="Die Kaffeemaschine soll es Benutzern ermöglichen, verschiedene Kaffeegetränke zuzubereiten. Das System steuert automatisch den Brühvorgang und überwacht Ressourcen wie Wasser, Bohnen und Becher. Der Benutzer wird üvber den Status informiert und bei Problemen gewarnt" vertex="1">
          <mxGeometry height="170" width="250" x="80" y="250" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="3. Systemgrenzen" vertex="1">
          <mxGeometry height="30" width="140" x="60" y="540" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-8" parent="1" style="whiteSpace=wrap;html=1;" value="System besteht aus Benutzerschnittstelle (Anzeige) und interner Hardware." vertex="1">
          <mxGeometry height="60" width="250" x="80" y="570" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="5. Nicht funktionale Anforderungen" vertex="1">
          <mxGeometry height="30" width="220" x="400" y="220" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-11" parent="1" style="whiteSpace=wrap;html=1;" value="- Bedienung einfach und intuitiv&lt;div&gt;- Anzeige in vertändliche Bilder&lt;/div&gt;&lt;div&gt;- Touch Screen Oberfläche&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="290" x="420" y="250" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="6. Annahmen und Abhängigkeiten" vertex="1">
          <mxGeometry height="30" width="220" x="400" y="370" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-13" parent="1" style="whiteSpace=wrap;html=1;" value="- Benutzer stellt die Tasse bereit&lt;div&gt;- Wasser und Kaffeebohnen sind nachfüllbar&lt;/div&gt;&lt;div&gt;- Reparatur nur durch Wartungspersonal möglich&lt;/div&gt;&lt;div&gt;- Das System soll die Zustände erkennen und eventuelle Fehler melden können.&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="250" x="420" y="410" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-14" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="7. Use - Cases" vertex="1">
          <mxGeometry height="30" width="130" x="400" y="550" as="geometry" />
        </mxCell>
        <mxCell id="ss95rz__1RLRhlweLFFE-15" parent="1" style="whiteSpace=wrap;html=1;" value="UC1: Getränk zubereiten&lt;div&gt;UC2: Wasser nachfüllen&lt;/div&gt;&lt;div&gt;UC3: Bohnen nachfüllen&lt;/div&gt;&lt;div&gt;UC4: Maschine reinigen&lt;/div&gt;&lt;div&gt;UC5: Wartung melden&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="160" x="420" y="580" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
