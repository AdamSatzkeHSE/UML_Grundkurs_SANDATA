        <mxCell id="gSoVFlYKqDo_zVxQMp8s-1" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" value="Erklärung&lt;div&gt;Der Fahrer nutzt (über das Farhzeug) externe Dienste (Wetterdienst). Anfragen werden an das externe System gestellt und Antworten zurückgeliefert.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Beispiel:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Fahrzeug fragt Wetterdaten ab&lt;/li&gt;&lt;li&gt;Externes Wetterdienst liefert Antwort&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="360" x="90" y="130" as="geometry" />
        </mxCell>
        <mxCell id="gSoVFlYKqDo_zVxQMp8s-2" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" value="&lt;b&gt;Schnittstelle Fahrer - Wetterdienst&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Entitäten:&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Wetterdienst&lt;/li&gt;&lt;li&gt;Fahrzeug&lt;/li&gt;&lt;li&gt;Wetterdaten&lt;/li&gt;&lt;li&gt;Fahrer&lt;/li&gt;&lt;li&gt;Anfrage&lt;/li&gt;&lt;li&gt;Antwort&lt;/li&gt;&lt;li&gt;Standort&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="320" x="470" y="130" as="geometry" />
        </mxCell>
        <mxCell id="J24QD6wrOYsMGg2ZyVJa-15" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" value="&lt;b&gt;Beschreibung der Beziehungen:&lt;/b&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;Ein Wetterdienst kriegt eine Anfrage und liefert eine Antwort&lt;/div&gt;&lt;div&gt;Ein Fahrer hat ein Fahrzeug&lt;/div&gt;&lt;div&gt;Ein Farhzeug liefert eine oder mehrere Anfragen&lt;/div&gt;&lt;div&gt;Ein Farhzeug kriegt keine oder mehrere Antworten&lt;br&gt;Wetterdaten haben einen Standort&lt;/div&gt;&lt;div&gt;Ein Wetterdienst kennt mehrere Wetterdaten&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
